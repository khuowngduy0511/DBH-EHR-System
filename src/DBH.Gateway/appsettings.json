{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "your-super-secret-key-for-jwt-token-generation-min-32-chars",
    "Issuer": "DBH.Auth.Service",
    "Audience": "DBH.EHR.System"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 30
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 500
      },
      {
        "Endpoint": "post:/api/v1/auth/login",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "post:/api/v1/auth/register",
        "Period": "1h",
        "Limit": 100
      }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-api": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/auth/{**catch-all}"
          }
        ]
      },
      "auth-did": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/did/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/did/{**catch-all}"
          }
        ]
      },
      "auth-patients": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/patients/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/patients/{**catch-all}"
          }
        ]
      },
      "auth-doctors": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/doctors/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/doctors/{**catch-all}"
          }
        ]
      },
      "auth-staff": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/staff/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/staff/{**catch-all}"
          }
        ]
      },
      "auth-swagger": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/services/auth/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/services/auth"
          }
        ]
      },
      "org-api": {
        "ClusterId": "organization-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/organizations/{**catch-all}"
