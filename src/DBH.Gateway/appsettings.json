        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "auth-service-1": {
            "Address": "http://auth_service:5101"
          }
        }
      },
      "organization-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
