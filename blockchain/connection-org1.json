{
    "name": "dbh-ehr-network-org1",
    "version": "1.0.0",
    "client": {
        "organization": "Org1MSP",
        "connection": {
            "timeout": {
                "peer": {
                    "endorser": "300"
                }
            }
        }
    },
    "organizations": {
        "Org1MSP": {
            "mspid": "Org1MSP",
            "peers": [
                "peer0.org1.dbh.com"
            ],
            "certificateAuthorities": [
                "ca.org1.dbh.com"
            ]
        }
    },
    "peers": {
        "peer0.org1.dbh.com": {
            "url": "grpcs://localhost:7051",
            "tlsCACerts": {
                "path": "organizations/peerOrganizations/org1.dbh.com/tlsca/tlsca.org1.dbh.com-cert.pem"
            },
            "grpcOptions": {
                "ssl-target-name-override": "peer0.org1.dbh.com",
                "hostnameOverride": "peer0.org1.dbh.com"
            }
        }
    },
    "certificateAuthorities": {
        "ca.org1.dbh.com": {
            "url": "https://localhost:7054",
            "caName": "ca-org1",
            "tlsCACerts": {
                "path": "organizations/peerOrganizations/org1.dbh.com/ca/ca.org1.dbh.com-cert.pem"
            },
            "httpOptions": {
                "verify": false
            }
        }
    }
}
