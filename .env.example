# =============================================================================
# DBH-EHR System - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# 
# WARNING: Never commit .env file with real secrets to Git!
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=dbh_ehr

# PostgreSQL Replication
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=your_replication_password_here

# -----------------------------------------------------------------------------
# ASP.NET Core Configuration
# -----------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development

# -----------------------------------------------------------------------------
# AI / LightRAG Configuration
# Dùng cho container lightrag trong docker-compose (truyền vào OPENAI_API_KEY)
# Lấy key tại: https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-your-key-here